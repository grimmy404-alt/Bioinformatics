file= input("Enter File Name:")
with open(file,"r") as f:
    data= f.read().split("\n")

s= data[0]
t= data[1]

if len(s)<len(t):
    exit()

motif_length= len(t)
positions=[]

for i in range(len(s)-len(t)+1):
    if s[i:i+motif_length]== t:
        positions.append(i+1)

result= " ".join(str(i) for i in positions)

print (result)